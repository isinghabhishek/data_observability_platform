# OpenLineage / Marquez
OPENLINEAGE_URL=http://localhost:5000
OPENLINEAGE_NAMESPACE=data_observability_platform
OPENLINEAGE_TRANSPORT_RETRY_ATTEMPTS=3
OPENLINEAGE_TRANSPORT_RETRY_BACKOFF=2

# Warehouse
WAREHOUSE_URL=postgresql://postgres:postgres@localhost:5432/observability

# Alerting
ALERT_CHANNEL=slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SMTP_HOST=smtp.example.com
SMTP_PORT=587
ALERT_EMAIL_TO=team@example.com
ALERT_SUPPRESSION_WINDOW_HOURS=4

# SLA Monitor
SLA_POLL_INTERVAL_MINUTES=60

# dbt
DBT_PROFILES_DIR=./dbt_project

# Marquez
MARQUEZ_URL=http://localhost:5000

# Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=observability
