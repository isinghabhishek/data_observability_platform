FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY pyproject.toml ./
RUN pip install --no-cache-dir -e "." 2>/dev/null || pip install --no-cache-dir \
    fastapi uvicorn apscheduler httpx pydantic pyyaml sqlalchemy psycopg2-binary

# Copy application source
COPY src/ ./src/
COPY sla_config.yml ./sla_config.yml

# Expose FastAPI port
EXPOSE 8080

# Run the SLA Monitor FastAPI app
CMD ["uvicorn", "src.sla_api:app", "--host", "0.0.0.0", "--port", "8080"]
